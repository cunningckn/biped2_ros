  <joint name="world_to_base_fixed" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_height}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="world_to_base_fixed">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>

  <!-- Demo mode: no gravity on links; legs move only via joint trajectory -->
  <gazebo reference="base_link">
    <gravity>false</gravity>
  </gazebo>
  <gazebo reference="RightHipYaw_Link"><gravity>false</gravity></gazebo>
  <gazebo reference="RightHipRoll_Link"><gravity>false</gravity></gazebo>
  <gazebo reference="RightHipPitch_Link"><gravity>false</gravity></gazebo>
  <gazebo reference="RightKneePitch_Link"><gravity>false</gravity></gazebo>
  <gazebo reference="RightAnklePitch_Link"><gravity>false</gravity></gazebo>
  <gazebo reference="LeftHipYaw_Link"><gravity>false</gravity></gazebo>
  <gazebo reference="LeftHipRoll_Link"><gravity>false</gravity></gazebo>
  <gazebo reference="LeftHipPitch_Link"><gravity>false</gravity></gazebo>
  <gazebo reference="LeftKneePitch_Link"><gravity>false</gravity></gazebo>
  <gazebo reference="LeftAnklePitch_Link"><gravity>false</gravity></gazebo>

  <!-- Symmetric standing pose: both feet at the same height -->
  <gazebo reference="LeftHipYaw">
    <initialPosition>0.0</initialPosition>
  </gazebo>
  <gazebo reference="LeftHipRoll">
    <initialPosition>0.0</initialPosition>
  </gazebo>
  <gazebo reference="LeftHipPitch">
    <initialPosition>0.0155</initialPosition>
  </gazebo>
  <gazebo reference="LeftKneePitch">
    <initialPosition>-0.0268</initialPosition>
  </gazebo>
  <gazebo reference="LeftAnklePitch">
    <initialPosition>0.0</initialPosition>
  </gazebo>
  <gazebo reference="RightHipYaw">
    <initialPosition>0.0</initialPosition>
  </gazebo>
  <gazebo reference="RightHipRoll">
    <initialPosition>0.0</initialPosition>
  </gazebo>
  <gazebo reference="RightHipPitch">
    <initialPosition>-0.0155</initialPosition>
  </gazebo>
  <gazebo reference="RightKneePitch">
    <initialPosition>0.0268</initialPosition>
  </gazebo>
  <gazebo reference="RightAnklePitch">
    <initialPosition>0.0</initialPosition>
  </gazebo>

  <gazebo>
    <plugin name="gazebo_ros_joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>50</update_rate>
    <joint_name>LeftHipYaw</joint_name>
    <joint_name>LeftHipRoll</joint_name>
    <joint_name>LeftHipPitch</joint_name>
    <joint_name>LeftKneePitch</joint_name>
    <joint_name>LeftAnklePitch</joint_name>
    <joint_name>RightHipYaw</joint_name>
    <joint_name>RightHipRoll</joint_name>
    <joint_name>RightHipPitch</joint_name>
    <joint_name>RightKneePitch</joint_name>
    <joint_name>RightAnklePitch</joint_name>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="gazebo_ros_joint_pose_trajectory" filename="libgazebo_ros_joint_pose_trajectory.so">
      <ros>
        <namespace>/</namespace>
        <remapping>set_joint_trajectory:=/joint_trajectory_controller/joint_trajectory</remapping>
      </ros>
      <update_rate>50</update_rate>
    </plugin>
  </gazebo>

  <gazebo reference="RightAnklePitch_Link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>
  <gazebo reference="LeftAnklePitch_Link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

</robot>
